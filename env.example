# Copier vers `.env.local` — requis pour NextAuth + DB (voir messages au démarrage si manquant).

# Secret de signature des cookies / tokens (générer : openssl rand -base64 32)
AUTH_SECRET=

# URL canonique de l’app (doit correspondre à l’URL dans le navigateur, ex. http://localhost:3000)
AUTH_URL=http://localhost:3000

# Alias historiques NextAuth v4 (optionnels si AUTH_* déjà définis)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# Base Neon / Postgres pour l’adapter Drizzle (sessions en base)
DATABASE_URL=

# Magic link Resend (provider `next-auth/providers/resend`)
AUTH_RESEND_KEY=
EMAIL_FROM="Futur One <noreply@votredomaine.com>"
